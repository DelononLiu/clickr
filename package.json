{
  "name": "clickr",
  "version": "1.0.0",
  "description": "跨平台桌面AI助手",
  "main": "src/main/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/DelononLiu/clickr.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build:dir": "electron-builder --win --dir",
    "build:web": "next build",
    "dev:web": "next dev"
  },
  "dependencies": {
    "active-win": "^9.0.0",
    "clipboardy": "^5.3.1",
    "next": "^16.1.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@tailwindcss/postcss": "^4.1.17",
    "tailwindcss": "^4.1.17",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.0"
  },
  "build": {
    "appId": "com.clickr.app",
    "productName": "Clickr",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["portable"]
    },
    "portable": {
      "artifactName": "Clickr.exe"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/active-win/**/*"
    ]
  },
  "keywords": ["ai", "assistant", "desktop", "electron"],
  "author": "",
  "license": "MIT"
}