{
  "name": "clickr",
  "version": "1.0.0",
  "type": "nextjs",
  "build": {
    "command": "npm run build:web",
    "outputDir": ".next",
    "installCommand": "npm install --ignore-scripts"
  },
  "platform": "kilo",
  "cleanInstall": true,
  "env": {
    "OPENAI_API_KEY": {
      "required": false,
      "description": "OpenAI API Key (optional for demo)"
    },
    "OPENAI_BASE_URL": {
      "required": false,
      "default": "https://api.openai.com/v1"
    },
    "OPENAI_MODEL": {
      "required": false,
      "default": "gpt-3.5-turbo"
    },
    "NPM_CONFIG_IGNORE_SCRIPTS": {
      "required": false,
      "default": "true",
      "description": "Skip native module builds (active-win) during install"
    }
  }
}

