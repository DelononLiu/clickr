{
  "name": "clickr",
  "version": "1.0.0",
  "type": "static",
  "build": {
    "command": "bun install && bun run build:web",
    "outputDir": "public",
    "installCommand": "bun install"
  },
  "platform": "kilo",
  "cleanInstall": true,
  "env": {
    "OPENAI_API_KEY": {
      "required": false,
      "description": "OpenAI API Key (optional for demo)"
    },
    "OPENAI_BASE_URL": {
      "required": false,
      "default": "https://api.openai.com/v1"
    },
    "OPENAI_MODEL": {
      "required": false,
      "default": "gpt-3.5-turbo"
    }
  },
  "routes": [
    {
      "source": "/*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/*",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}

